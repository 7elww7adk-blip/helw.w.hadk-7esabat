generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole { OWNER MANAGER ACCOUNTANT DELIVERY_AGENT VIEWER }
enum BranchType { MAIN SUB }
enum BranchStatus { ACTIVE INACTIVE }
enum PaymentMethod { CASH CARD BANK_TRANSFER CREDIT }
enum TransferType { INVENTORY_TRANSFER CASH_TRANSFER EXPENSE_ALLOCATION CAPITAL_SUPPORT SETTLEMENT }
enum DeliveryAgentStatus { ACTIVE INACTIVE }
enum DeliveryFeeModelType { PER_ORDER FIXED_DAILY PERCENTAGE CUSTOM }
enum OrderPaymentType { CASH ONLINE MIXED CREDIT }
enum OrderStatus { NEW READY OUT_FOR_DELIVERY DELIVERED RETURNED CANCELLED DEFERRED PARTIALLY_SETTLED }
enum DeliveryRunStatus { OPEN IN_PROGRESS RETURNED SETTLED UNDER_REVIEW }
enum DeliverySettlementStatus { MATCHED SHORTAGE OVERAGE REVIEW_REQUIRED }
enum StocktakeStatus { SHORTAGE SURPLUS MATCHED }
enum CashTransactionType { INFLOW OUTFLOW }
enum CapitalMovementType { INJECTION WITHDRAWAL }

model User {
  id String @id @default(cuid())
  name String
  email String @unique
  passwordHash String
  role UserRole
  branchId String?
  branch Branch? @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdTransfers BranchTransfer[] @relation("TransferCreator")
  settlements DriverSettlement[] @relation("SettledBy")
}

model Branch {
  id String @id @default(cuid())
  name String
  code String @unique
  type BranchType
  parentBranchId String?
  parentBranch Branch? @relation("BranchHierarchy", fields: [parentBranchId], references: [id])
  subBranches Branch[] @relation("BranchHierarchy")
  openingDate DateTime
  status BranchStatus
  managerName String?
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users User[]
  setup BranchSetup?
  dailyEntries DailyEntry[]
  purchases Purchase[]
  expenses Expense[]
  cashTransactions CashTransaction[]
  stocktakes Stocktake[]
  capitalMovements CapitalMovement[]
  fromTransfers BranchTransfer[] @relation("FromBranch")
  toTransfers BranchTransfer[] @relation("ToBranch")
  deliveryAgents DeliveryAgent[]
  orders Order[]
  runs DeliveryRun[]
  settlements DriverSettlement[]
}

model BranchSetup {
  id String @id @default(cuid())
  branchId String @unique
  branch Branch @relation(fields: [branchId], references: [id])
  openingDate DateTime
  openingCashCapital Decimal @db.Decimal(12,2)
  openingInventoryValue Decimal @db.Decimal(12,2)
  openingCashboxBalance Decimal @db.Decimal(12,2)
  openingNotes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyEntry {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id])
  date DateTime
  totalSales Decimal @db.Decimal(12,2)
  totalReturns Decimal @db.Decimal(12,2)
  purchases Decimal @db.Decimal(12,2)
  operatingExpenses Decimal @db.Decimal(12,2)
  ownerWithdrawals Decimal @db.Decimal(12,2)
  deposits Decimal @db.Decimal(12,2)
  transfersIn Decimal @db.Decimal(12,2)
  transfersOut Decimal @db.Decimal(12,2)
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([branchId, date])
}

model Purchase { id String @id @default(cuid()) branchId String branch Branch @relation(fields:[branchId],references:[id]) date DateTime supplier String amount Decimal @db.Decimal(12,2) paymentMethod PaymentMethod notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model Expense { id String @id @default(cuid()) branchId String branch Branch @relation(fields:[branchId],references:[id]) date DateTime category String amount Decimal @db.Decimal(12,2) description String paymentMethod PaymentMethod notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model CashTransaction { id String @id @default(cuid()) branchId String branch Branch @relation(fields:[branchId],references:[id]) date DateTime type CashTransactionType amount Decimal @db.Decimal(12,2) description String createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model Stocktake { id String @id @default(cuid()) branchId String branch Branch @relation(fields:[branchId],references:[id]) date DateTime actualInventoryValue Decimal @db.Decimal(12,2) expectedInventoryValue Decimal @db.Decimal(12,2) difference Decimal @db.Decimal(12,2) status StocktakeStatus countedBy String notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model CapitalMovement { id String @id @default(cuid()) branchId String branch Branch @relation(fields:[branchId],references:[id]) date DateTime type CapitalMovementType amount Decimal @db.Decimal(12,2) notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }

model BranchTransfer {
  id String @id @default(cuid())
  date DateTime
  fromBranchId String
  toBranchId String
  type TransferType
  amount Decimal @db.Decimal(12,2)
  notes String?
  createdById String
  createdBy User @relation("TransferCreator", fields:[createdById], references:[id])
  fromBranch Branch @relation("FromBranch", fields:[fromBranchId], references:[id])
  toBranch Branch @relation("ToBranch", fields:[toBranchId], references:[id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings { id String @id @default(cuid()) companyName String defaultCurrency String @default("EGP") timezone String @default("Africa/Cairo") requireDriverSettlementReview Boolean @default(true) notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }

model DeliveryAgent { id String @id @default(cuid()) name String phone String branchId String branch Branch @relation(fields:[branchId], references:[id]) status DeliveryAgentStatus feeModelType DeliveryFeeModelType feeValue Decimal @db.Decimal(10,2) notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt orders Order[] runs DeliveryRun[] settlements DriverSettlement[] }

model Order {
  id String @id @default(cuid())
  orderNumber String @unique
  branchId String
  branch Branch @relation(fields:[branchId],references:[id])
  customerName String
  customerPhone String
  address String
  orderAmount Decimal @db.Decimal(12,2)
  deliveryFee Decimal @db.Decimal(12,2)
  totalDue Decimal @db.Decimal(12,2)
  paymentType OrderPaymentType
  status OrderStatus
  assignedDriverId String?
  assignedDriver DeliveryAgent? @relation(fields:[assignedDriverId],references:[id])
  assignedAt DateTime?
  deliveredAt DateTime?
  returnedAt DateTime?
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  runEntries DeliveryRunOrder[]
}

model DeliveryRun { id String @id @default(cuid()) branchId String driverId String branch Branch @relation(fields:[branchId],references:[id]) driver DeliveryAgent @relation(fields:[driverId],references:[id]) startTime DateTime endTime DateTime? status DeliveryRunStatus totalOrders Int @default(0) totalOrderAmount Decimal @db.Decimal(12,2) @default(0) totalDeliveryFees Decimal @db.Decimal(12,2) @default(0) totalDue Decimal @db.Decimal(12,2) @default(0) notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt runOrders DeliveryRunOrder[] settlement DriverSettlement? }
model DeliveryRunOrder { id String @id @default(cuid()) runId String orderId String run DeliveryRun @relation(fields:[runId],references:[id]) order Order @relation(fields:[orderId],references:[id]) orderStatusInRun OrderStatus collectedAmount Decimal? @db.Decimal(12,2) notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt @@unique([runId, orderId]) }
model DriverSettlement { id String @id @default(cuid()) runId String @unique driverId String branchId String expectedAmount Decimal @db.Decimal(12,2) actualReturnedAmount Decimal @db.Decimal(12,2) driverFee Decimal @db.Decimal(12,2) shortage Decimal @db.Decimal(12,2) overage Decimal @db.Decimal(12,2) status DeliverySettlementStatus settledById String settledAt DateTime notes String? run DeliveryRun @relation(fields:[runId],references:[id]) driver DeliveryAgent @relation(fields:[driverId],references:[id]) branch Branch @relation(fields:[branchId],references:[id]) settledBy User @relation("SettledBy", fields:[settledById],references:[id]) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
